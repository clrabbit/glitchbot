DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
# Optional: restrict deployment to a single guild during dev (faster than global)
# GUILD_ID=your_guild_id_here
WEB_URL=https://bot.glitch.fm
PORT=3003
# Starboard: channel where starred messages are reposted (3+ ⭐/🌟 reactions)
STARBOARD_CHANNEL_ID=519233898660626438
# Logging: channel where edited messages are logged
EDIT_LOG_CHANNEL_ID=416631355091320843
# Bot owner Discord user ID — required for /logging enable/disable
OWNER_ID=your_discord_user_id_here
# Voice Role: role assigned to users active in voice in the last 7 days
VOICE_ROLE_ID=1019834905435308153
